# Anthropic API 키 (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# ── Google AdSense (선택 — 없으면 광고 placeholder 표시) ──
# ads.txt용: ca-pub- 또는 pub- 로 시작해도 됨
# ADSENSE_PUBLISHER_ID=pub-1234567890123456

# 광고 스크립트·슬롯 (Vite 빌드 시 포함 — Render에서도 Build 시 필요)
# VITE_ADSENSE_CLIENT=ca-pub-1234567890123456
# VITE_ADSENSE_SLOT_BANNER=1234567890
# VITE_ADSENSE_SLOT_RECTANGLE=1234567890
# VITE_ADSENSE_SLOT_LEADERBOARD=1234567890

# 선택: 모델 변경 (기본 claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# 선택: 스크린샷 OCR 전용 모델 (기본 claude-haiku-4-5)
# ANTHROPIC_OCR_MODEL=claude-haiku-4-5

# API 서버 포트 (기본 3001)
# PORT=3001
